        "id": "HXsvqnssQO9s"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "# Using IQR Method for High Financial Columns\n",
        "# ------------------------------------------------\n",
        "iqr_cols = [\n",
        "    'Annual_Income',\n",
        "    'Monthly_Inhand_Salary',\n",
        "    'Outstanding_Debt'\n",
        "]\n",
        "\n",
        "for col in iqr_cols:\n",
        "\n",
        "    # Calculate Q1 and Q3\n",
        "    Q1 = p_df[col].quantile(0.25)\n",
        "    Q3 = p_df[col].quantile(0.75)\n",
        "\n",
        "    # Calculate IQR\n",
        "    IQR = Q3 - Q1\n",
        "\n",
        "    # Define lower and upper bounds\n",
        "    lower_bound = Q1 - 1.5 * IQR\n",
        "    upper_bound = Q3 + 1.5 * IQR\n",
        "\n",
        "    # Capping outliers\n",
        "    # clip() caps extreme values within limits\n",
        "    p_df[col] = p_df[col].clip(lower=lower_bound, upper=upper_bound)\n",
        "\n",
        "    print(f\"Outliers handled in {col} using IQR method\")"
      ],
      "metadata": {
        "colab": {
          "base_uri": "https://localhost:8080/"
